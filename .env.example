# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================================
# GENERIC
# =============================================================================
DOMAIN=yourdomain.com
PUBLIC=yourdomain2.com
LOCAL=yourlocalname        # LAN DNS suffix (e.g. lan, local, home)
HEYSHUTUP=heyshutup.com   # Third domain for heyshutup app TLS cert
TZ=America/New_York
DOCKERDIR=/home/youruser/docker
DOCKERNET=proxy
PUID=1000
GUID=1000

# =============================================================================
# CLOUDFLARE
# =============================================================================
CF_API_EMAIL=you@email.com
CF_DNS_API_TOKEN=your_cloudflare_dns_api_token
CFAPI=your_cloudflare_api_token
CLOUDFLARED_TOKEN=your_cloudflare_tunnel_token  # from: cloudflared tunnel token

# =============================================================================
# TRAEFIK
# =============================================================================
# Generate with: htpasswd -nb admin yourpassword | sed 's/\$/\$\$/g'
TRAEFIKADMIN=admin:$$2y$$05$$yourhashhere

# =============================================================================
# GRAFANA
# =============================================================================
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=changeme

# =============================================================================
# UNIFI POLLER
# =============================================================================
POLLER_TAG=latest
POLLER_DEBUG=false
POLLER_SAVE_DPI=true
UNIFI_USER=readonly_user
UNIFI_PASS=your_unifi_password
UNIFI_URL=https://192.168.1.1
UNIFI_DYNAMIC=true

# =============================================================================
# POSTGRESQL (shared DB for Outline, Tandoor, Docmost, etc.)
# =============================================================================
PGUSER=your_db_user
PGPASS=your_db_password
PGDB=your_db_name

# =============================================================================
# SMTP (Brevo / Sendinblue or other provider)
# =============================================================================
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
MAIL_FROM_ADDRESS=authelia@yourdomain.com
MAIL_FROM_NAME=Auth

# =============================================================================
# TANDOOR RECIPES
# =============================================================================
# Generate with: base64 /dev/urandom | head -c50
SECRET_KEY=your_django_secret_key
DB_ENGINE=django.db.backends.postgresql
POSTGRES_HOST=db_recipes
POSTGRES_DB=djangodb
POSTGRES_PORT=5432
POSTGRES_USER=djangouser
POSTGRES_PASSWORD=your_tandoor_db_password

# =============================================================================
# KOPIA BACKUP
# =============================================================================
KOPIA_USER=admin
KOPIA_PASS=your_kopia_web_password
KOPIA_REPO_PW=your_kopia_repository_password

# =============================================================================
# GOTIFY
# =============================================================================
GOTIFY_DEFAULTUSER_PASS=changeme

# =============================================================================
# DIUN (Docker image update notifier)
# =============================================================================
DIUN_GOTIFY_TOKEN=your_gotify_api_token

# =============================================================================
# REDIS
# =============================================================================
REDIS_PASSWORD=your_redis_password  # Used by Authelia, Traefik provider, redis-exporter, Grafana datasource

# =============================================================================
# ADGUARD EXPORTER
# =============================================================================
ADGUARD_PASSWORDS=your_adguard_password,your_second_adguard_password

# =============================================================================
# NZBGET EXPORTER
# =============================================================================
NZBGET_PASSWORD=your_nzbget_password

# =============================================================================
# MEALIE OIDC (plaintext values, used in docker-compose for Mealie service)
# =============================================================================
MEALIE_OIDC_CLIENT_ID=your_mealie_client_id
MEALIE_OIDC_CLIENT_SECRET=your_mealie_client_secret_plaintext

# =============================================================================
# AUTHELIA OIDC CLIENTS (loaded via {{ env }} template in authelia/configuration.yml)
# Generate client_ids and client_secrets with:
#   docker run authelia/authelia:latest authelia crypto hash generate pbkdf2 \
#     --random --random.length 64 --random.charset alphanumeric
# Run twice per client: once for client_id (store plaintext), once for client_secret
#   (store plaintext in app config, pbkdf2 digest here for Authelia)
# =============================================================================
OIDC_BESZEL_CLIENT_ID=your_beszel_client_id
OIDC_BESZEL_CLIENT_SECRET='$pbkdf2-sha512$310000$...'
OIDC_CLOUDFLARE_CLIENT_ID=your_cloudflare_client_id
OIDC_CLOUDFLARE_CLIENT_SECRET='$pbkdf2-sha512$310000$...'
OIDC_DOCMOST_CLIENT_ID=your_docmost_client_id
OIDC_DOCMOST_CLIENT_SECRET='$pbkdf2-sha512$310000$...'
OIDC_GRAFANA_CLIENT_ID=your_grafana_client_id
OIDC_GRAFANA_CLIENT_SECRET='$pbkdf2-sha512$310000$...'
OIDC_GUACAMOLE_CLIENT_ID=your_guacamole_client_id
OIDC_GUACAMOLE_CLIENT_SECRET='$pbkdf2-sha512$310000$...'
OIDC_IMMICH_CLIENT_ID=your_immich_client_id
OIDC_IMMICH_CLIENT_SECRET='$pbkdf2-sha512$310000$...'
OIDC_MEALIE_CLIENT_ID=your_mealie_client_id
OIDC_MEALIE_CLIENT_SECRET='$pbkdf2-sha512$310000$...'
OIDC_OPENWEBUI_CLIENT_ID=your_openwebui_client_id
OIDC_OPENWEBUI_CLIENT_SECRET='$pbkdf2-sha512$310000$...'
OIDC_OUTLINE_CLIENT_ID=your_outline_client_id
OIDC_OUTLINE_CLIENT_SECRET='$pbkdf2-sha512$310000$...'
OIDC_PORTAINER_CLIENT_ID=your_portainer_client_id
OIDC_PORTAINER_CLIENT_SECRET='$pbkdf2-sha512$310000$...'
OIDC_PROXMOX_CLIENT_ID=your_proxmox_client_id
OIDC_PROXMOX_CLIENT_SECRET='$pbkdf2-sha512$310000$...'
OIDC_SYNOLOGY_CLIENT_ID=your_synology_client_id
OIDC_SYNOLOGY_CLIENT_SECRET='$pbkdf2-sha512$310000$...'
OIDC_TANDOOR_CLIENT_ID=your_tandoor_client_id
OIDC_TANDOOR_CLIENT_SECRET='$pbkdf2-sha512$310000$...'
