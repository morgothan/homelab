server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  # Use a persistent path (bind-mounted from host) so restarts don't re-replay large files
  filename: /etc/promtail/positions.yaml

clients:
  - url: http://loki.yourlocalname:3100/loki/api/v1/push

scrape_configs:
  - job_name: syslog
    syslog:
      listen_address: 0.0.0.0:1514
      idle_timeout: 60s
      label_structured_data: yes
      labels:
        job: "syslog"
    relabel_configs:
      - source_labels: ['__syslog_message_hostname']
        target_label: 'host'

  # Tail Traefik access log file (not available via Docker socket since it goes to a file, not stdout)
  # Requires volume mount: ${DOCKERDIR}/traefik/logs:/var/log/traefik:ro
  # Pre-seed positions.yaml with current file size to avoid replaying the full history on first start
  - job_name: traefik_access
    static_configs:
      - targets:
          - localhost
        labels:
          job: traefik
          host: traefik.yourlocalname
          __path__: /var/log/traefik/access.log

  - job_name: docker
    docker_sd_configs:
      - host: "unix:///var/run/docker.sock"
        refresh_interval: 15s
    relabel_configs:
      - source_labels: ['__meta_docker_container_name']
        regex: '/(.*)'
        target_label: 'container'
